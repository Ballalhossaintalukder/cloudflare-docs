---
/**
 * RelatedProduct — 2-column row showing a CF product icon, the product
 * name as a link, and a slotted description. Used in the "Related
 * products" section of product landing pages.
 *
 * CF source: cloudflare-docs/src/components/RelatedProduct.astro
 *
 * Mapping notes:
 *   - `product` is a bare icon name resolved by astro-icon against the
 *     local set in `src/icons/`. Those SVGs use `fill="currentColor"`, so
 *     the icon follows the element's text color.
 */
import { z } from "astro/zod";
import { Icon as AstroIcon } from "astro-icon/components";

const props = z.object({
  header: z.string(),
  href: z.string(),
  product: z.string(),
});

const { header, href, product } = props.parse(Astro.props);
---

<div class="grid grid-cols-[32px_auto] items-start gap-x-2 mb-3">
  <AstroIcon name={product} class="text-3xl text-muted-foreground" />
  <div class="mt-0!">
    <strong>
      <a href={href} class="text-foreground! decoration-brand">{header}</a>
    </strong>
    <slot />
  </div>
</div>
